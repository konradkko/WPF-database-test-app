<Window x:Class="WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        xmlns:viewModel="clr-namespace:WPF.ViewModel"
        mc:Ignorable="d"
        Title="Crypt" Height="600" Width="800">
    <Window.DataContext>
        <viewModel:MainViewModel x:Name="MainVM"/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="389*"/>
            <ColumnDefinition Width="11*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="20,20,20,20">
            <StackPanel Orientation="Vertical">
                <Label Content="Nazwa:" Width="50px" Padding="0px" FontSize="15"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                <Label Content="Dane:" Width="40px" Padding="0px" FontSize="15"/>
                <TextBox Text="{Binding UserEntry, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                <Label Content="Klucz:" Width="40px" Padding="0px" FontSize="15"/>
                <PasswordBox x:Name="PasswordBoxMasterKey"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Szyfruj" Width="250px" Click="Click_Encrypt" Margin="30,15,30,15" Height="25"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <ListView Width="150" Height="220" DisplayMemberPath="Name" x:Name="DataListBox" SelectionChanged="DataListBox_ItemSelected"
                              SelectedItem="{Binding SelectedItem}" ItemsSource="{Binding ListaDanychZaszyfrowanych, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="20,0,20,0" />
                <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                    <Label MaxWidth="200px" Content="{Binding SelectedNameLabel}"/>
                    <Label MaxWidth="200px" Content="{Binding SelectedDataLabel}"/>
                    <Button Content="Usuń wpis" Width="150px" Click="Click_DeleteRecord" Height="25" Margin="10,10,10,0"/>
                    <Button Content="Odszyfruj" Width="150px" Click="Click_Decrypt" Height="25" Margin="10,10,10,10"/>
                    <TextBox Width="200px" Text="{Binding Result, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                </StackPanel>
            </StackPanel>
            
        </StackPanel>
        <TextBox Background="LightGray" FontFamily="Consolas" VerticalScrollBarVisibility="Auto"
                 Text="{Binding Log_tb, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Grid.ColumnSpan="2" Margin="0,292,0,0" Grid.RowSpan="2"/>
    </Grid>
</Window>
